\par \page }{\cs15\b\fs18\cf1\up6\insrsid13787376 ${\footnote \pard\plain \s16\ql \li0\ri0\sl-240\slmult1\widctlpar\wrapdefault\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {
